MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
ROUTESCAN_MANTLE_API_URL=https://api.routescan.io/v2/network/mainnet/evm/5000/etherscan/api
DEFILLAMA_PRICES_URL=https://coins.llama.fi/prices/current
DEFILLAMA_YIELDS_URL=https://yields.llama.fi/pools

# Optional: enables the real LLM agent report path.
# Runtime flow: collect Mantle data -> LLM generates report -> publish hashes on-chain -> return report with tx proof in the UI.
OPENROUTER_API_KEY=
AI_MODEL=openai/gpt-5.4-mini

DEPLOYER_PRIVATE_KEY=
MANTLESCAN_API_KEY=
NEXT_PUBLIC_RWA_GUARDIAN_ADDRESS=
NEXT_PUBLIC_MANTLE_SEPOLIA_CHAIN_ID=5003
# Production demo uses PORT=3004 behind Nginx/aaPanel reverse proxy.
PORT=3004

# Prevents free user-triggered repeat audits from spamming the deployer wallet.
# Default in code is 3600 seconds (1 hour).
AUDIT_CACHE_TTL_SECONDS=3600
AUDIT_CACHE_DB_PATH=./data/audit-cache.sqlite

# Optional PM2-friendly self-updater. When enabled, the running server checks
# origin/main periodically, validates updates, and exits 0 for PM2 autorestart.
AUTO_DEPLOY=false
AUTO_DEPLOY_BRANCH=main
AUTO_DEPLOY_INTERVAL_MS=60000
